{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "tse_core/**"
      }
    },
    {
      "src": "*.{html,css,js}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/index", "dest": "/api/index.py" },
    { "src": "/", "dest": "/index.html" },
    { "handle": "filesystem" }
  ]
}
